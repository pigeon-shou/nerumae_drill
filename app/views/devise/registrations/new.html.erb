<div class="min-h-screen bg-slate-50 flex flex-col">

  <!-- ヘッダー -->
  <header class="p-4 bg-white border-b flex items-center shadow-sm">
    <h1 class="text-lg font-bold text-indigo-600">ねるまえドリル</h1>
  </header>

  <main class="flex-grow max-w-md mx-auto w-full px-6 py-8">

    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mb-2">アカウント作成</h2>
      <p class="text-sm text-slate-500">まずは5分の復習習慣をはじめましょう</p>
    </div>

    <div class="bg-white rounded-[32px] p-8 shadow-xl border">

      <%= form_with model: resource,
          as: resource_name,
          url: registration_path(resource_name),
          class: "space-y-5" do |f| %>

        <!-- nickname追加（ここが今回の本体） -->
        <div>
          <%= f.label :nickname, class: "text-xs text-slate-400" %>
          <%= f.text_field :nickname,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "ニックネーム" %>
        </div>

        <!-- email -->
        <div>
          <%= f.label :email, class: "text-xs text-slate-400" %>
          <%= f.email_field :email,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "example@mail.com" %>
        </div>

        <!-- password -->
        <div>
          <%= f.label :password, class: "text-xs text-slate-400" %>
          <%= f.password_field :password,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "••••••••" %>
        </div>

        <!-- password confirmation -->
        <div>
          <%= f.label :password_confirmation, class: "text-xs text-slate-400" %>
          <%= f.password_field :password_confirmation,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "••••••••" %>
        </div>

        <!-- submit -->
        <%= f.submit "登録する",
          class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-2xl shadow-lg active:scale-95 transition" %>

      <% end %>

    </div>

    <!-- ログインリンク -->
    <div class="mt-8 text-center">
      <%= link_to "ログインはこちら", new_session_path(resource_name),
          class: "text-indigo-600 font-bold text-sm" %>
    </div>

  </main>
</div>