<div class="min-h-screen bg-slate-50 flex flex-col">

  <!-- ヘッダー -->
  <header class="p-4 bg-white border-b flex items-center shadow-sm">
    <h1 class="text-lg font-bold text-indigo-600">ねるまえドリル</h1>
  </header>

  <main class="flex-grow max-w-md mx-auto w-full px-6 py-8">

    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mb-2">プロフィール編集</h2>
      <p class="text-sm text-slate-500">アカウント情報を更新できます</p>
    </div>

    <div class="bg-white rounded-[32px] p-8 shadow-xl border">

      <%= form_with model: resource,
        url: registration_path(resource_name),
        method: :patch,
        local: true,
        class: "space-y-5" do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <!-- nickname -->
        <div>
          <%= f.label :nickname, class: "text-xs text-slate-400" %>
          <%= f.text_field :nickname,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "ニックネーム" %>
        </div>

        <!-- email -->
        <div>
          <%= f.label :email, class: "text-xs text-slate-400" %>
          <%= f.email_field :email,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "example@mail.com" %>
        </div>

        <!-- password -->
        <div>
          <%= f.label :password, class: "text-xs text-slate-400" %>
          <p class="text-[10px] text-slate-400 mb-1">変更しない場合は空欄</p>
          <%= f.password_field :password,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "••••••••" %>
        </div>

        <!-- password confirmation -->
        <div>
          <%= f.label :password_confirmation, class: "text-xs text-slate-400" %>
          <%= f.password_field :password_confirmation,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "••••••••" %>
        </div>

        <!-- current password -->
        <div>
          <%= f.label :current_password, class: "text-xs text-slate-400" %>
          <p class="text-[10px] text-slate-400 mb-1">変更を保存するために必要です</p>
          <%= f.password_field :current_password,
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "現在のパスワード" %>
        </div>

        <!-- submit -->
        <%= f.submit "更新する",
          class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-2xl shadow-lg active:scale-95 transition" %>

      <% end %>

    </div>

    <!-- アカウント削除 -->
    <div class="mt-8 text-center">
      <p class="text-xs text-slate-400 mb-2">アカウントを削除する場合</p>

      <%= button_to "アカウント削除",
          registration_path(resource_name),
          method: :delete,
          data: { turbo_confirm: "本当に削除しますか？" },
          class: "text-red-500 font-bold text-sm" %>
    </div>

    <!-- 戻る -->
    <div class="mt-6 text-center">
      <%= link_to "戻る",
          user_path(current_user),
          class: "text-slate-400 text-sm font-bold hover:text-indigo-600" %>
    </div>

  </main>
</div>