
<div class="min-h-screen bg-slate-50 flex flex-col">

  <!-- ヘッダー -->
  <header class="p-4 bg-white border-b flex items-center shadow-sm">
    <h1 class="text-lg font-bold text-indigo-600">ねるまえドリル</h1>
  </header>

  <main class="flex-grow max-w-md mx-auto w-full px-6 py-10">

    <!-- タイトル -->
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mb-2">ログイン</h2>
      <p class="text-sm text-slate-500">復習を再開しましょう</p>
    </div>

    <!-- カード -->
    <div class="bg-white rounded-[32px] p-8 shadow-xl border">

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <!-- email -->
        <div class="mb-5">
          <%= f.label :email, class: "text-xs text-slate-400 mb-2 block" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "example@mail.com" %>
        </div>

        <!-- password -->
        <div class="mb-5">
          <%= f.label :password, class: "text-xs text-slate-400 mb-2 block" %>
          <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full p-4 rounded-2xl bg-slate-50 border ring-1 ring-slate-200 focus:ring-2 focus:ring-indigo-400",
              placeholder: "••••••••" %>
        </div>

        <!-- remember me -->
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center mb-6 text-sm text-slate-500">
            <%= f.check_box :remember_me, class: "mr-2" %>
            <%= f.label :remember_me %>
          </div>
        <% end %>

        <!-- submit -->
        <%= f.submit "ログイン",
          class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-2xl shadow-lg active:scale-95 transition" %>

      <% end %>

    </div>

    <!-- links -->
    <div class="mt-8 text-center space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </main>

</div>