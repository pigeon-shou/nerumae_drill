<%= render "shared/header" %>

<div class="min-h-screen bg-slate-950 text-slate-100 flex flex-col">

  <!-- 中央寄せ（微調整） -->
  <div class="flex-grow flex items-start justify-center px-4 pt-16 pb-8">

    <div class="w-full max-w-md">

      <!-- 進捗バー -->
      <div class="mb-8">

        <div class="flex justify-between items-end mb-2">
          <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
            Progress
          </p>

          <p class="text-xs font-bold text-slate-400">
            のこり 
            <span id="remaining-count" class="text-indigo-400 text-sm">
              <%= @learnings.count %>
            </span>
            問
          </p>
        </div>

        <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
          <div id="progress-bar"
            class="bg-indigo-500 h-full transition-all duration-500"
            style="width: 0%">
          </div>
        </div>

      </div>

      <!-- カード -->
      <div id="quiz-container">

        <% @learnings.each_with_index do |learning, index| %>
          
          <div class="quiz-card <%= 'hidden' if index != 0 %>"
               data-index="<%= index %>">

            <div class="bg-slate-900 rounded-3xl p-10 shadow-xl border border-slate-800 transition transform hover:scale-[1.02]">

              <h2 class="text-3xl font-bold text-white mb-5 leading-relaxed">
                <%= learning.content %>
              </h2>

              <p class="keyword-toggle cursor-pointer select-none
                  bg-slate-800 border border-slate-700
                  text-slate-300 text-center py-3 px-4 rounded-xl
                  hover:bg-slate-700 active:scale-[0.98]
                  transition"
                data-answer="<%= learning.keyword %>">
                👆答えを見る
              </p>

            </div>

          </div>

        <% end %>

      </div>

      <!-- ボタン -->
      <div class="mt-8">
        <button id="next-button"
          class="w-full bg-indigo-600 hover:bg-indigo-500 text-white text-lg font-bold py-5 rounded-2xl shadow-lg transition active:scale-95 shadow-indigo-500/30">
          思い出した！
        </button>
      </div>

    </div>

  </div>

</div>

<%= render "shared/footer" %>