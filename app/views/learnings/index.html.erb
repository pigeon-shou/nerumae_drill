<%= render "shared/header" %>

<!-- 背景 -->
<div class="min-h-screen bg-slate-950 text-slate-100">

  <div class="max-w-md mx-auto px-4 py-6 space-y-4">

    <% @learnings.each do |learning| %>

      <!-- カード -->
      <div class="bg-slate-900 rounded-3xl  p-6 shadow-lg border border-slate-800 active:scale-[0.98] hover:scale-[1.01] transition transform">

        <!-- タイトル -->
        <h2 class="text-xl font-bold text-white mb-3 leading-snug">
          <%= learning.content %>
        </h2>

        <!-- キーワード -->
        <p class="text-sm text-slate-400">
          <%= learning.keyword %>
        </p>

      </div>

    <% end %>

    <!-- 新規作成ボタン -->
    <%= link_to '新しく覚える', new_learning_path,
      class: "block text-center mt-6 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-2xl shadow-lg transition" %>

  </div>
</div>

<%= render "shared/footer" %>